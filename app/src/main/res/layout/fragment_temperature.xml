<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Temperature:"
        android:textSize="16sp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/editTextTemp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 25"
        android:inputType="numberDecimal"
        android:textSize="18sp"
        android:padding="12dp" />

    <RadioGroup
        android:id="@+id/radioGroupTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radioCtoF"
            android:layout_width="228dp"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Celsius → Fahrenheit"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/radioFtoC"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fahrenheit → Celsius"
            android:textSize="16sp" />

    </RadioGroup>

    <Button
        android:id="@+id/buttonConvertTemp"
        android:layout_width="236dp"
        android:layout_height="wrap_content"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:text="CONVERT"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/textViewResultTemp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Result: —"
        android:textSize="22sp"
        android:textStyle="bold" />

</LinearLayout>